# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini — https://aistudio.google.com/apikey (ücretsiz tier)
GEMINI_API_KEY=
# Opsiyonel: gemini-2.0-flash (varsayılan) veya gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash

# WhatsApp Cloud API (Meta) — https://developers.facebook.com
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=randevuai-verify
WHATSAPP_APP_SECRET=

# Google Calendar OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Places / Maps — aynı Cloud projesinde Places API (New) etkinleştirin
GOOGLE_MAPS_API_KEY=

# Cron (Vercel) — rastgele uzun bir string
CRON_SECRET=
